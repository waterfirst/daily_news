# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Financial Data APIs
STOCK_API_KEY=your_stock_api_key_here
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key_here

# News APIs
NEWS_API_KEY=your_news_api_key_here
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# Database Configuration
DATABASE_URL=sqlite:///data/database.db
DATABASE_BACKUP_ENABLED=true

# Scheduler Configuration
TIMEZONE=Asia/Seoul
ENABLE_SCHEDULER=true

# Service Configuration
ETF_SERVICE_ENABLED=true
NEWS_SERVICE_ENABLED=true
CONTENT_SERVICE_ENABLED=true
BEAUTY_NEWS_ENABLED=true
DISPLAY_NEWS_ENABLED=true
SEMICONDUCTOR_NEWS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/daip.log

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=30

# Debug Mode
DEBUG=false
